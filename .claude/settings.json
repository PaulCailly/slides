{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run lint:*)",
      "Bash(npm run build:*)",
      "Bash(npm run dev:*)",
      "Bash(npm run preview:*)",
      "Bash(npm install:*)",
      "Bash(npx eslint:*)",
      "Bash(node --check:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(awk:*)",
      "Bash(jq:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)"
    ],
    "deny": [
      "Bash(git push origin main:*)",
      "Bash(git push origin master:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/guard-bash.sh"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/guard-large-read.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/lint-on-edit.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/verify-slides.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "agent",
            "prompt": "You are the deck integrity checker. Quickly verify three things by running shell commands — do not read slides-data.js wholesale:\n\n1. The section ranges in src/App.jsx cover every slide number in src/slides-data.js with no gaps and no overlaps.\n2. Every slide variant used in slides-data.js (e.g. 'cover', 'question') is handled in App.jsx's slideClasses logic.\n3. No slide body references a closing </div> count that mismatches its opening <div> count (a common bug when editing the raw string).\n\nIf everything is consistent, output exactly: OK. Otherwise, report the specific problem in one sentence with the slide number and let the main agent fix it.",
            "timeout": 90
          }
        ]
      }
    ]
  }
}
